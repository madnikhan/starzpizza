rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Menu images - allow read for everyone, write for admin
    match /menu-images/{imageId} {
      allow read: if true; // Anyone can view images
      allow write: if true; // Allow uploads (admin dashboard)
    }
    // Banner images and videos (hero slideshow) - public read, admin write
    match /banner-images/{fileId} {
      allow read: if true;
      allow write: if true;
    }
    match /banner-videos/{fileId} {
      allow read: if true;
      allow write: if true;
    }
  }
}

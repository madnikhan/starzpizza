rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Orders collection
    match /orders/{orderId} {
      // Allow anyone to create orders (for public checkout)
      // Check that required fields are present
      allow create: if request.resource.data.keys().hasAll(['items', 'orderType', 'paymentMethod', 'customerInfo', 'subtotal', 'total', 'status', 'createdAt']) &&
                       request.resource.data.items is list &&
                       request.resource.data.items.size() > 0 &&
                       request.resource.data.customerInfo.phone is string &&
                       request.resource.data.customerInfo.name is string;
      
      // Allow read for anyone (for order confirmation pages)
      // In production, you might want to restrict this to order owners
      allow read: if true;
      
      // Allow updates to all fields (for admin dashboard)
      // In production, add authentication check here
      allow update: if true;
      
      // Allow deletes (for admin dashboard)
      // In production, add authentication check here
      allow delete: if true;
    }
    
    // Menu items (read-only for public, write for admin)
    match /menu/{itemId} {
      allow read: if true;
      allow create: if true; // Allow creation (admin dashboard)
      allow update: if true; // Allow updates (admin dashboard)
      allow delete: if true; // Allow deletes (admin dashboard)
    }
    
    // Restaurant status - public read, write for admin
    match /restaurant_status/{document=**} {
      allow read: if true; // Anyone can read status
      allow write: if true; // For now, allow writes (should be restricted to admins later)
    }
  }
}

